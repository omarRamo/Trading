{
  "name": "Revolut Trading Streamlit",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "github.vscode-github-actions"
      ]
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -r requirements.txt",
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit",
      "onAutoForward": "openBrowser"
    }
  },
  "postAttachCommand": "echo \"Run: python -m streamlit run app.py --server.address 0.0.0.0 --server.port 8501\""
}
